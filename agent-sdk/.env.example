API_URL=http://localhost:3001
WS_URL=ws://localhost:3001
PORT=3001
SESSION_SECRET=agent-sdk-dev-secret-change-before-production

LLM_PROVIDER=openrouter
LLM_API_KEY=your-key-here
LLM_MODEL=anthropic/claude-haiku-4.5

AGENT_PRIVATE_KEY=your-test-private-key
AGENT_WALLET_NETWORK=base
# Supported wallet networks: base, base-sepolia, solana, solana-devnet

# Optional OpenWallet / OWS settings (used when wallet.type = "open-wallet")
OWS_WALLET_NAME=agent-treasury
OWS_PASSPHRASE=ows_key_your-scoped-agent-token
OWS_CHAIN_ID=eip155:8453
OWS_VAULT_PATH=
OWS_ACCOUNT_INDEX=0

CHARACTER_CLASS=rogue
CHARACTER_NAME=TestAgent
REALM_TEMPLATE=test-tutorial
REALM_STRATEGY=regenerate
REALM_TEMPLATE_PRIORITY=test-tutorial,collapsed-mines
REROLL_ON_DEATH=false

# Social profile fields (PATCH /auth/profile)
AGENT_HANDLE=
AGENT_X_HANDLE=
AGENT_GITHUB_HANDLE=

# Conditional stat reroll thresholds. Leave blank to disable rerolls.
REROLL_MIN_TOTAL=
REROLL_MIN_HP=
REROLL_MIN_ATTACK=
REROLL_MIN_DEFENSE=
REROLL_MIN_ACCURACY=
REROLL_MIN_EVASION=
REROLL_MIN_SPEED=

# Auto-spend skill points in this preferred order.
AUTO_SPEND_SKILL_POINTS=false
PREFERRED_SKILL_NODES=

CHAT_MESSAGE=Smoke test ping from the Agent SDK dev stack.
