# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
out/
build/
*.tsbuildinfo

# Turbo
.turbo/

# Environment files — NEVER commit real secrets
# Root .env has service keys — never commit
/.env
/.env.local
/.env.*.local
/.env.production
# Backend env (inherits from root .env at runtime)
/backend/.env
/backend/.env.local
# frontend/.env is committed — only contains NEXT_PUBLIC_ vars (safe, client-side by design)
frontend/.env.local
frontend/.env.production

# Bun
bun.lockb

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Vercel
.vercel

# Redis dump
dump.rdb
