{
  "name": "adventure-fun",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared/*",
    "agent-sdk",
    "player-agent"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:watch": "turbo test --watch",
    "dev": "turbo dev --filter=@adventure-fun/web --filter=@adventure-fun/server",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.1.0"
  }
}
