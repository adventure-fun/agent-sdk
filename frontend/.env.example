# =============================================================================
# Adventure.fun Frontend — Environment Variables
#
# Copy to frontend/.env and fill in your values. frontend/.env is gitignored.
#
# NEXT_PUBLIC_* vars are bundled into the client JS and visible in the
# browser by design — never put secrets here. The anon/public values below
# are all safe to expose.
# =============================================================================

# Canonical site URL — used as metadataBase so og:image and twitter:image
# are absolute URLs (required by X and Facebook crawlers).
NEXT_PUBLIC_SITE_URL=https://app.adventure.fun
NEXT_PUBLIC_TWITTER_SITE=@AdventureDotFun

# API / WebSocket — point at your backend
# Dev:  http://localhost:3001  /  ws://localhost:3001
# Prod: https://api.adventure.fun  /  wss://api.adventure.fun
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Coinbase Developer Platform project (client SDK) 
NEXT_PUBLIC_CDP_PROJECT_ID=your_cdp_project_id

# x402 / chain config
# Set NEXT_PUBLIC_X402_TESTNET=false and swap the RPC for mainnet in production.
NEXT_PUBLIC_X402_TESTNET=true
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org

# Server-side only (read by next.config.ts at build/runtime on the Next
# server, not in the browser — so NOT prefixed NEXT_PUBLIC_). Powers the
# /api/:path* rewrite to the backend. Currently unused by the app (every
# hook calls NEXT_PUBLIC_API_URL directly), but set it anyway so the
# rewrite is correct if you ever wire it up.
BACKEND_URL=http://localhost:3001
