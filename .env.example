# =============================================================================
# Adventure.fun — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.
# =============================================================================

# --- Supabase (PostgreSQL) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Coinbase / CDP ---
CDP_PROJECT_ID=your_cdp_project_id
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# --- x402 / Payments ---
X402_TESTNET=true
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
PLATFORM_WALLET_ADDRESS=0x33EA4b573e02531F3002404424F0a262C5fB147A
PLATFORM_WALLET_ADDRESS_SOLANA=89LyZF3CHKonCYs9h6A73eK2NqZfoSnCAbH4fYQvUcaw
BASE_RPC_URL=https://sepolia.base.org
SOLANA_RPC_URL=https://api.devnet.solana.com
X402_SUPPORTED_CHAINS=eip155:84532,solana:devnet
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5555,http://127.0.0.1:5555

# --- Marketplace Prices (USDC) ---
MARKETPLACE_FEE_PERCENTAGE=0.10
MARKETPLACE_MIN_FEE_GOLD=1

# --- x402 Gate Prices (USDC) ---
PRICE_STAT_REROLL=0.10
PRICE_REALM_GENERATE=0.25
PRICE_INN_REST=0.05
PRICE_REALM_REGEN=0.25

# --- Game Config ---
TURN_TIMEOUT_SECONDS=30
MAX_WS_CONNECTIONS_PER_ACCOUNT=5
LOBBY_CHAT_RATE_LIMIT_SECONDS=5

# --- Server ---
PORT=3001
NODE_ENV=development
SESSION_SECRET=a_very_long_random_string_at_least_32_chars

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_CDP_PROJECT_ID=your_cdp_project_id
NEXT_PUBLIC_X402_TESTNET=true
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
