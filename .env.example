# =============================================================================
# Adventure.fun — Environment Variables (root)
#
# Copy to .env and fill in your values. NEVER commit .env — it is gitignored.
# Backend reads this file via `bun --env-file ../.env`. Frontend picks up
# NEXT_PUBLIC_* at build time.
# =============================================================================

# --- Supabase (server-side only) ---
# Service role key bypasses RLS. Never expose to the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Redis ---
# Local dev defaults to localhost. In production, point at your managed
# Redis (e.g. on Railway, use ${{Redis.REDIS_URL}} reference).
REDIS_URL=redis://localhost:6379

# --- Coinbase / CDP (server-side credentials) ---
CDP_PROJECT_ID=your_cdp_project_id
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# --- x402 / Payments ---
# Set X402_TESTNET=false and switch RPC URLs + wallet addresses to mainnet
# values for production.
X402_TESTNET=true
X402_FACILITATOR_URL=https://x402.org/facilitator
PLATFORM_WALLET_ADDRESS=0xYourEvmWallet
PLATFORM_WALLET_ADDRESS_SOLANA=YourSolanaWallet
BASE_RPC_URL=https://sepolia.base.org
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- x402 Gate Prices (USDC) ---
# Set any price to 0 to make the action free.
PRICE_STAT_REROLL=0.25
PRICE_REALM_GENERATE=0
PRICE_INN_REST=0.25
PRICE_REALM_REGEN=0.25

# --- CORS ---
# Comma-separated list of allowed origins for the backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5555,http://127.0.0.1:5555

# --- Game Config ---
TURN_TIMEOUT_SECONDS=30
MAX_WS_CONNECTIONS_PER_ACCOUNT=5
LOBBY_CHAT_RATE_LIMIT_SECONDS=5
SPECTATE_CHAT_RATE_LIMIT_SECONDS=5

# --- Server ---
# PORT is optional locally (defaults to 3001). Railway and most PaaS
# providers inject their own PORT — do not hardcode in production.
PORT=3001
NODE_ENV=development
# Must be a strong random string (>=32 chars) in production. The backend
# refuses to start in production if this is missing or matches the default.
# Generate with: openssl rand -hex 32
SESSION_SECRET=a_very_long_random_string_at_least_32_chars

# --- Frontend ---
# Frontend env vars live in frontend/.env (see frontend/.env.example).
# This root file is backend-only.
