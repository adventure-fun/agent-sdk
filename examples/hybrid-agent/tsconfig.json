{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "../../src/**/*.ts",
    "../super-agent/**/*.ts",
    "../arena-agent/**/*.ts"
  ],
  "exclude": [
    "./tests/**/*.ts",
    "../super-agent/tests/**/*.ts",
    "../arena-agent/tests/**/*.ts"
  ]
}
