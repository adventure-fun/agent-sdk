  "narrative": {
    "theme_description": "A cave system beneath a dying forest. The roots overhead glow faintly violet where the Hollow's corruption seeps upward. The first Guardian \u2014 a ranger \u2014 sealed the Hollow here centuries ago. The seal is cracking.",
    "room_text_pool": [
      {
        "text": "Gnarled roots twist down from the ceiling, their tips glowing a sickly violet. The air is thick with spores.",
        "type": "combat"
      },
      {
        "text": "A pack of wolves blocks the passage ahead. Their fur is matted with something dark, and their eyes burn with unnatural light.",
        "type": "combat"
      },
      {
        "text": "Clusters of luminescent fungi cling to the walls. Some pulse slowly, releasing clouds of fine spores into the still air.",
        "type": "trap"
      },
      {
        "text": "A natural spring bubbles up through cracked stone. The water is clear but carries a faint violet shimmer.",
        "type": "rest"
      },
      {
        "text": "A chest sits nestled among the roots, half-buried in moss. Something about it feels wrong \u2014 the moss around it is dead.",
        "type": "treasure"
      },
      {
        "text": "Ancient carvings cover the wall \u2014 a figure with a bow, standing before a great darkness. The stone is cracked, and violet light seeps through.",
        "type": "event"
      },
      {
        "text": "The roots here form a natural archway. Beyond it, the corruption is visibly thicker \u2014 the stone itself seems to sweat violet moisture.",
        "type": "event"
      }
    ],
    "lore_pool": [
      "hollow-ranger-seal",
      "hollow-spore-bestiary",
      "hollow-wolf-bestiary",
      "hollow-seal-cracking"
    ],
